-- ======== LOADING SEQUENCE ========
local steps = {
	{pct = 15, msg = "Initializing..."},
	{pct = 35, msg = "Loading assets..."},
	{pct = 55, msg = "Building GUI..."},
	{pct = 75, msg = "Building GUI..."},
	{pct = 90, msg = "Finishing up..."},
	{pct = 100, msg = "Done!"},
}

-- Animate open
TweenService:Create(loadPanel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
	Size = UDim2.new(0, panelW, 0, panelH),
}):Play()

-- Spin the circle icon
local spinAngle = 0
local spinConn
spinConn = game:GetService("RunService").Heartbeat:Connect(function(dt)
	spinAngle = spinAngle + dt * 120
	loadIcon.Rotation = spinAngle
end)

-- Run loading steps
task.spawn(function()
	for _, step in ipairs(steps) do
		task.wait(0.55)
		loadStatus.Text = step.msg
		loadPct.Text = step.pct .. "%"
		TweenService:Create(barFill, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(step.pct / 100, 0, 1, 0)
		}):Play()
	end

	task.wait(0.4)
	spinConn:Disconnect()

	-- Transition to version selector
	TweenService:Create(loadPanel, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0)
	}):Play()

	task.wait(0.4)
	loadPanel:Destroy()

	mainPanel.Size = UDim2.new(0, 0, 0, 0)
	mainPanel.Position = UDim2.new(0.5, 0, 0.5, 0)
	mainPanel.Visible = true

	TweenService:Create(mainPanel, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, panelW, 0, panelH),
		Position = UDim2.new(0.5, -panelW/2, 0.5, -panelH/2)
	}):Play()
end)
