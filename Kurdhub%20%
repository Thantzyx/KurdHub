-- Starfield dots
local function spawnDots(parent, count)
	for i = 1, count do
		local dot = Instance.new("Frame")
		dot.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
		dot.Position = UDim2.new(math.random(), 0, math.random(), 0)
		dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		dot.BackgroundTransparency = math.random(50, 80) / 100
		dot.BorderSizePixel = 0
		dot.ZIndex = 2
		dot.Parent = parent
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(1, 0)
		corner.Parent = dot

		-- twinkle
		local function twinkle()
			local t = TweenService:Create(dot, TweenInfo.new(math.random(10, 30) / 10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {BackgroundTransparency = math.random(10, 40) / 100})
			t:Play()
		end
		task.delay(math.random() * 3, twinkle)
	end
end

